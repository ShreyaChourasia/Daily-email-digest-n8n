    {
      "parameters": {
        "jsCode": "const emails = $input.first().json.emails;\n\nconst bullets = emails.map(e => {\n  const subject = e.subject || '(No Subject)';\n  const from = e.from || 'Unknown';\n  const summary = e.summary || 'No summary available';\n  return `• *${subject}* (from: ${from})\\n  _${summary}_`;\n}).join('\\n\\n');\n\nconst count = emails.length;\nconst date = new Date().toLocaleDateString('en-US', {\n  weekday: 'long',\n  year: 'numeric',\n  month: 'short',\n  day: 'numeric'\n});\n\nconst message = `📬 *Daily Email Digest — ${date}*\\n\\n` +\n  `*${count} unread email${count !== 1 ? 's' : ''}* summarized:\\n\\n` +\n  bullets;\n\nreturn [{ json: { slackMessage: message, emailCount: count } }];"
      },
      "id": "a703339f-aa3b-441e-9406-e4db01ceb855",
